{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cougargrades-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-02-14",
  // "compatibility_flags": [
  //   "nodejs_compat"
  // ],
  "observability": {
    "enabled": true
  },
  "routes": [
    {
      "pattern": "api.cougargrades.io",
      "zone_name": "cougargrades.io",
      "custom_domain": true
    }
  ],
  "vars": {
    //"GOOGLE_APPLICATION_CREDENTIALS": "JSON.parse(base64_decode({\"type\":\"service_account\",\"project_id\":\"...\", ...))",
    // Fake credential that passes the build step (since we validate the environment variable early)
    // {"type":"service_account","project_id":"cougargrades-testing","private_key_id":"(redacted)","private_key":"-----BEGIN PRIVATE KEY-----\n(redacted)\n-----END PRIVATE KEY-----\n","client_email":"(redacted)","client_id":"(redacted)","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"(redacted)"}
    "GOOGLE_APPLICATION_CREDENTIALS": ""
  },
  "env": {
    "preview": {
      "routes": [
        {
          "pattern": "next.api.cougargrades.io",
          "zone_name": "cougargrades.io",
          "custom_domain": true
        }
      ],
      "vars": {
        // Fake credential that passes the build step (since we validate the environment variable early)
        "GOOGLE_APPLICATION_CREDENTIALS": ""
      },
    }
  },
  // "sec"
  // "kv_namespaces": [
  //   {
  //     "binding": "MY_KV_NAMESPACE",
  //     "id": "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
  //   }
  // ],
  // "r2_buckets": [
  //   {
  //     "binding": "MY_BUCKET",
  //     "bucket_name": "my-bucket"
  //   }
  // ],
  // "d1_databases": [
  //   {
  //     "binding": "MY_DB",
  //     "database_name": "my-database",
  //     "database_id": ""
  //   }
  // ],
  // "ai": {
  //   "binding": "AI"
  // },
  
  // "observability": {
  //   "enabled": true,
  //   "head_sampling_rate": 1
  // }
}